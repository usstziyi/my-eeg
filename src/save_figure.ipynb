   "source": [
    "def save_figure(filename=\"figure.pdf\"):\n",
    "    plt.savefig(\n",
    "        filename,        # 矢量格式，放大不失真（适合论文投稿）\n",
    "        dpi=300,             # 高分辨率用于印刷\n",
    "        bbox_inches=\"tight\",\n",
    "        facecolor=\"white\",   # 背景色（默认透明，论文常需白色）\n",
    "        pad_inches=0.1       # 裁剪后额外保留的边距\n",
    "    )\n"
   ]
  }
 ],
